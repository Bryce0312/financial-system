{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "paths": {
      "@financial-system/types": [
        "packages/types/src"
      ],
      "@financial-system/types/*": [
        "packages/types/src/*"
      ],
      "@financial-system/ui": [
        "packages/ui/src"
      ],
      "@financial-system/ui/*": [
        "packages/ui/src/*"
      ],
      "@financial-system/config/*": [
        "packages/config/*"
      ]
    }
  }
}

